# ===== CHAVES DE API - SENTIMENT ANALYSIS =====

# Twitter API v2 (https://developer.twitter.com/en/portal/dashboard)
TWITTER_BEARER=your_bearer_token_here

# Reddit API (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT=your_client_id
REDDIT_SECRET=your_client_secret

# Telegram (opcional, requer setup adicional)
TELEGRAM_ID=your_phone_number_or_id
TELEGRAM_HASH=your_api_hash

# NewsAPI (https://newsapi.org)
NEWSAPI_KEY=your_newsapi_key

# Telegram Bot (para notificações - opcional)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ===== BLOCKCHAIN CONFIGURATION =====

# Polygon RPC
POLYGON_RPC=https://polygon-rpc.com
POLYGON_RPC_BACKUP=https://rpc-mainnet.maticvigil.com

# Sua chave privada (NUNCA compartilhe!)
# Gere uma nova wallet apenas para este bot com fundos limitados
PRIVATE_KEY=0xsua_chave_privada_aqui

# Endereço do contrato FlashTrader já deployado
# Após fazer deploy do contrato, copie o endereço aqui
CONTRACT_ADDRESS=0xseu_contrato_aqui

# ===== PARÂMETROS DO BOT =====

# Capital em USDC por operação (deve ter esse valor em sua wallet)
CAPITAL_POR_OP=3000

# Spread mínimo esperado (em decimal: 0.03 = 3%)
SPREAD_MINIMO=0.03

# Score de sentimento para trigger (entre -1 e 1)
# 0.3 significa sentimento positivo moderado
SCORE_LIMIAR=0.3

# Intervalo entre scans em segundos
INTERVALO=60

# Mode teste (não executa transações reais)
DRY_RUN=true

# Categoria do Polymarket (afeta taxas)
CATEGORIA=geopolitics

# Mercados para monitorar (comma-separated)
MERCADOS=BTC,ETH,SOL

# ===== MODO DE EXECUÇÃO =====
# Quando DRY_RUN=true: o bot simula operações sem enviar transações reais
# Quando DRY_RUN=false: o bot executa transações reais com sua chave privada
# 
# ⚠️ ANTES DE USAR EM PRODUÇÃO:
# 1. Teste com DRY_RUN=true por pelo menos 1 semana
# 2. Monitore performance e volatilidade
# 3. Comece com CAPITAL_POR_OP pequeno (ex: 100 USDC)
# 4. Tenha uma estratégia de stop loss clara
